rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check role privilege hierarchy
    function isHigherPrivilege(actorRole, targetRole) {
      return (targetRole == 'member' && (actorRole == 'admin' || actorRole == 'host' || actorRole == 'cohost')) ||
             (targetRole == 'cohost' && (actorRole == 'admin' || actorRole == 'host')) ||
             (targetRole == 'host' && actorRole == 'admin') ||
             (targetRole == 'admin' && actorRole == 'admin');
    }

    // 1. User documents (rate limits, targets checklist, streaks, and profile details)
    match /users/{userId} {
      allow read: if request.auth != null; // allow signed-in users to lookup profiles for the community directory
      allow create: if request.auth != null && request.auth.uid == userId &&
                    request.resource.data.keys().hasOnly(['lastRoomCreatedTime', 'targetsList', 'targetsHistory', 'currentStreak', 'lastActiveDate', 'currentWeekKey', 'displayName', 'photoURL', 'followersCount', 'followingCount', 'bio', 'activeTheme']) &&
                    (
                      !('lastRoomCreatedTime' in request.resource.data) || request.resource.data.lastRoomCreatedTime == request.time
                    );

      allow update: if request.auth != null &&
                    request.resource.data.keys().hasOnly(['lastRoomCreatedTime', 'targetsList', 'targetsHistory', 'currentStreak', 'lastActiveDate', 'currentWeekKey', 'displayName', 'photoURL', 'followersCount', 'followingCount', 'bio', 'activeTheme']) &&
                    (
                      request.auth.uid == userId ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount'])
                    ) &&
                    (
                      !('lastRoomCreatedTime' in request.resource.data) || 
                      resource.data.lastRoomCreatedTime == null ||
                      request.resource.data.lastRoomCreatedTime == resource.data.lastRoomCreatedTime || 
                      request.resource.data.lastRoomCreatedTime == request.time
                    );

      // Session history logs subcollection
      match /sessionLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Mutual connections subcollection (accepted connections gating)
      match /connections/{connectionId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 2. Follows collection (one-way public following system)
    match /follows/{followId} {
      allow read: if request.auth != null; // anyone signed-in can load counts and checks
      allow create: if request.auth != null 
        && request.auth.uid == request.resource.data.followerId
        && followId == (request.resource.data.followerId + '_' + request.resource.data.followingId);
      allow delete: if request.auth != null 
        && request.auth.uid == resource.data.followerId;
    }

    // Reports collection
    match /reports/{reportId} {
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if false;
    }
    
    // 3. Room documents: only creators or authorized participants can edit settings
    match /rooms/{roomId} {
      allow read: if true;
      
      // Whitelists creation fields (allows guest creators as well)
      allow create: if (
        (request.auth != null && request.resource.data.creatorId == request.auth.uid) ||
        (request.resource.data.creatorId.startsWith('guest_'))
      ) && 
      request.resource.data.keys().hasOnly(['id', 'name', 'type', 'buttonText', 'participants', 'maxParticipants', 'link', 'creatorId', 'creatorName', 'creatorEmail', 'createdAt', 'scheduledDate', 'scheduledTime', 'currentHostId', 'currentHostName']) &&
      (
        request.resource.data.creatorId.startsWith('guest_') ||
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        !('lastRoomCreatedTime' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
        request.time >= get(/databases/$(database)/documents/users/$(request.auth.uid)).data.lastRoomCreatedTime + duration.value(5, 's')
      );
        
      // Whitelists update fields
      allow update: if (
        (
          request.auth != null && 
          (
            resource.data.creatorId == request.auth.uid ||
            get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role in ['admin', 'host', 'cohost']
          )
        ) ||
        (
          resource.data.creatorId.startsWith('guest_')
        )
      ) && 
      request.resource.data.creatorId == resource.data.creatorId &&
      (
        !("voteStatus" in resource.data) || resource.data.voteStatus == request.resource.data.voteStatus ||
        (
          (request.resource.data.voteStatus == 'active' && 
           (
             (request.auth != null && (resource.data.creatorId == request.auth.uid || get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role in ['admin', 'host', 'cohost'])) ||
             (resource.data.creatorId.startsWith('guest_') && request.auth == null)
           )
          ) ||
          (request.resource.data.voteStatus == 'closed' &&
           (
             (request.auth != null && request.auth.uid == resource.data.voteCreatorId) ||
             (resource.data.voteCreatorId.startsWith('guest_') && request.auth == null) ||
             (
               !exists(/databases/$(database)/documents/rooms/$(roomId)/participants/$(resource.data.voteCreatorId)) &&
               (request.auth != null && (resource.data.creatorId == request.auth.uid || get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role in ['admin', 'host', 'cohost']))
             )
           )
          )
        )
      ) &&
      request.resource.data.keys().hasOnly([
        'id', 'name', 'type', 'buttonText', 'participants', 'maxParticipants', 'link', 'creatorId', 'creatorName', 'creatorEmail', 'createdAt', 'scheduledDate', 'scheduledTime', 'currentHostId', 'currentHostName',
        'todSpinResult', 'todSpinPool', 'todState', 'todChoice', 'todText', 'todSelectedId', 'todSpinInProgress',
        'spinResult', 'spinPool', 'spinCheckedIds',
        'emptySince', 'roomMode', 'allowFunTools',
        'voteQuestion', 'voteOptions', 'voteCreatorId', 'voteCreatorName', 'voteStatus', 'voteResults'
      ]);
        
      // Deletion rules
      allow delete: if (
        (request.auth != null && resource.data.creatorId == request.auth.uid) ||
        resource.data.creatorId.startsWith('guest_') ||
        (request.auth != null && (request.auth.token.email == 'fijakhan7127@gmail.com' || request.auth.token.email == '000fijakhan123@gmail.com'))
      );
      
      // 4. Participants presence: users can only write to their own presence document
      match /participants/{participantId} {
        allow read: if true;
        
        allow create: if (
                        request.auth != null && 
                        (
                          participantId == request.auth.uid &&
                          request.resource.data.keys().hasOnly(['uid', 'name', 'photoURL', 'initials', 'color', 'joinedAt', 'role', 'mutedBy', 'camOffBy', 'sessionId', 'isMuted', 'isCamOff', 'isSpeaking', 'isPinned', 'isHost', 'sharing', 'sharingYoutubeId', 'whiteboardData', 'ytPlaying', 'ytTime', 'ytUpdateTimestamp', 'ytSpeed', 'ytPlaylistIndex', 'ytVideoId', 'todJoined', 'todPending', 'todRequestedSpin', 'todRequestedChoice', 'todRequestedReset', 'whiteboardEditAllowed', 'micOn', 'camOn', 'micRestricted', 'camRestricted', 'status', 'handRaised', 'handRaisedAt', 'castVote']) &&
                          (
                            (request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.creatorId && request.resource.data.role == 'host') ||
                            ((request.auth.token.email == 'fijakhan7127@gmail.com' || request.auth.token.email == '000fijakhan123@gmail.com') && request.resource.data.role == 'admin') ||
                            (!(request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.creatorId) && 
                             !(request.auth.token.email == 'fijakhan7127@gmail.com' || request.auth.token.email == '000fijakhan123@gmail.com') && 
                             (
                               request.resource.data.role == 'member' ||
                               (exists(/databases/$(database)/documents/rooms/$(roomId)/approvedUsers/$(request.auth.uid)) && 
                                request.resource.data.role == get(/databases/$(database)/documents/rooms/$(roomId)/approvedUsers/$(request.auth.uid)).data.role)
                             ))
                          )
                        )
                      ) || 
                      (
                        participantId.startsWith('guest_') &&
                        request.resource.data.keys().hasOnly(['uid', 'name', 'photoURL', 'initials', 'color', 'joinedAt', 'role', 'mutedBy', 'camOffBy', 'sessionId', 'isMuted', 'isCamOff', 'isSpeaking', 'isPinned', 'isHost', 'sharing', 'sharingYoutubeId', 'whiteboardData', 'ytPlaying', 'ytTime', 'ytUpdateTimestamp', 'ytSpeed', 'ytPlaylistIndex', 'ytVideoId', 'todJoined', 'todPending', 'todRequestedSpin', 'todRequestedChoice', 'todRequestedReset', 'whiteboardEditAllowed', 'micOn', 'camOn', 'micRestricted', 'camRestricted', 'status', 'handRaised', 'handRaisedAt', 'castVote']) &&
                        (
                          request.resource.data.role == 'member' ||
                          (request.resource.data.role == 'host' && participantId == get(/databases/$(database)/documents/rooms/$(roomId)).data.creatorId) ||
                          (exists(/databases/$(database)/documents/rooms/$(roomId)/approvedUsers/$(participantId)) && 
                           request.resource.data.role == get(/databases/$(database)/documents/rooms/$(roomId)/approvedUsers/$(participantId)).data.role)
                        )
                      ) ||
                      (
                        participantId.matches('^bot_.*')
                      );
                      
        allow update: if (
                        request.auth != null && 
                        (
                          (
                            request.resource.data.keys().hasOnly(['uid', 'name', 'photoURL', 'initials', 'color', 'joinedAt', 'role', 'mutedBy', 'camOffBy', 'sessionId', 'isMuted', 'isCamOff', 'isSpeaking', 'isPinned', 'isHost', 'sharing', 'sharingYoutubeId', 'whiteboardData', 'ytPlaying', 'ytTime', 'ytUpdateTimestamp', 'ytSpeed', 'ytPlaylistIndex', 'ytVideoId', 'todJoined', 'todPending', 'todRequestedSpin', 'todRequestedChoice', 'todRequestedReset', 'whiteboardEditAllowed', 'micOn', 'camOn', 'micRestricted', 'camRestricted', 'status', 'handRaised', 'handRaisedAt', 'castVote']) &&
                            (
                              (participantId == request.auth.uid && 
                               (request.resource.data.role == resource.data.role || 
                                (resource.data.role == 'host' && (request.resource.data.role == 'cohost' || request.resource.data.role == 'member')) ||
                                (resource.data.role == 'cohost' && request.resource.data.role == 'member')
                               ) &&
                               (
                                 !request.resource.data.keys().hasAny(['micRestricted']) || 
                                 !resource.data.keys().hasAny(['micRestricted']) || 
                                 request.resource.data.micRestricted == resource.data.micRestricted ||
                                 (request.resource.data.micRestricted == true && request.resource.data.mutedBy in ['focus_limit', 'system']) ||
                                 (resource.data.micRestricted == true && request.resource.data.micRestricted == false && resource.data.mutedBy in ['focus_limit', 'system'])
                               ) &&
                               (!request.resource.data.keys().hasAny(['camRestricted']) || !resource.data.keys().hasAny(['camRestricted']) || request.resource.data.camRestricted == resource.data.camRestricted)
                              ) ||
                              (
                                participantId != request.auth.uid &&
                                isHigherPrivilege(get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role, resource.data.role) &&
                                (
                                  (request.resource.data.role != resource.data.role && 
                                   (
                                     (get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role == 'admin' && (request.resource.data.role == 'host' || request.resource.data.role == 'cohost' || request.resource.data.role == 'member')) ||
                                     (get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role == 'host' && (request.resource.data.role == 'host' || request.resource.data.role == 'cohost' || request.resource.data.role == 'member'))
                                   )
                                  ) ||
                                  (request.resource.data.role == resource.data.role && 
                                   get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role in ['admin', 'host', 'cohost'])
                                ) &&
                                (
                                  !request.resource.data.keys().hasAny(['micOn']) ||
                                  request.resource.data.micOn == false ||
                                  (
                                    resource.data.keys().hasAny(['micOn']) &&
                                    request.resource.data.micOn == resource.data.micOn
                                  )
                                ) &&
                                (
                                  !request.resource.data.keys().hasAny(['camOn']) ||
                                  request.resource.data.camOn == false ||
                                  (
                                    resource.data.keys().hasAny(['camOn']) &&
                                    request.resource.data.camOn == resource.data.camOn
                                  )
                                )
                              )
                            )
                          ) ||
                          // Allow watchers to edit whiteboard if allowed by the presenter
                          (
                            participantId != request.auth.uid &&
                            request.resource.data.keys().hasOnly(['uid', 'name', 'photoURL', 'initials', 'color', 'joinedAt', 'role', 'mutedBy', 'camOffBy', 'sessionId', 'isMuted', 'isCamOff', 'isSpeaking', 'isPinned', 'isHost', 'sharing', 'sharingYoutubeId', 'whiteboardData', 'ytPlaying', 'ytTime', 'ytUpdateTimestamp', 'ytSpeed', 'ytPlaylistIndex', 'ytVideoId', 'todJoined', 'todPending', 'todRequestedSpin', 'todRequestedChoice', 'todRequestedReset', 'whiteboardEditAllowed', 'micOn', 'camOn', 'micRestricted', 'camRestricted', 'status', 'handRaised', 'handRaisedAt', 'castVote']) &&
                            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['whiteboardData']) &&
                            resource.data.sharing == 'whiteboard' &&
                            resource.data.whiteboardEditAllowed == true &&
                            exists(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid))
                          )
                        )
                      ) ||
                      (
                        participantId.startsWith('guest_') &&
                        request.resource.data.keys().hasOnly(['uid', 'name', 'photoURL', 'initials', 'color', 'joinedAt', 'role', 'mutedBy', 'camOffBy', 'sessionId', 'isMuted', 'isCamOff', 'isSpeaking', 'isPinned', 'isHost', 'sharing', 'sharingYoutubeId', 'whiteboardData', 'ytPlaying', 'ytTime', 'ytUpdateTimestamp', 'ytSpeed', 'ytPlaylistIndex', 'ytVideoId', 'todJoined', 'todPending', 'todRequestedSpin', 'todRequestedChoice', 'todRequestedReset', 'whiteboardEditAllowed', 'micOn', 'camOn', 'micRestricted', 'camRestricted', 'status', 'handRaised', 'handRaisedAt', 'castVote'])
                      );
                      
        allow delete: if (
                        request.auth != null && 
                        (
                          participantId == request.auth.uid ||
                          participantId.matches('^bot_.*') ||
                          (
                            participantId != request.auth.uid &&
                            isHigherPrivilege(get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role, resource.data.role)
                          )
                        )
                      ) || 
                      participantId.startsWith('guest_');
      }
      
      // 5. Messages subcollection
      match /messages/{messageId} {
        allow read: if true;
        allow create: if (
                        (request.auth != null && request.resource.data.senderId == request.auth.uid) ||
                        (request.resource.data.senderId.startsWith('guest_')) ||
                        request.resource.data.senderId.matches('^bot_.*')
                      ) &&
                      request.resource.data.keys().hasOnly(['id', 'sender', 'senderId', 'senderRole', 'text', 'createdAt', 'mentionedId', 'deleted', 'edited']) &&
                      exists(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.resource.data.senderId));

        // Allow sender to soft-delete (set deleted=true) or edit their own message
        allow update: if (
          // Authenticated sender editing or soft-deleting their own message
          (request.auth != null && resource.data.senderId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'deleted', 'edited'])
          ) ||
          // Guest sender soft-deleting their own message
          (resource.data.senderId.startsWith('guest_') &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'deleted', 'edited'])
          ) ||
          // Moderator soft-deleting any message (set deleted=true)
          (request.auth != null &&
            get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role in ['admin', 'host', 'cohost'] &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'deleted'])
          )
        );

        // Allow sender or moderator to hard-delete (used by handleClearParticipantChat)
        allow delete: if (
          (request.auth != null && resource.data.senderId == request.auth.uid) ||
          (resource.data.senderId.startsWith('guest_')) ||
          (request.auth != null &&
            get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role in ['admin', 'host', 'cohost']
          )
        );
      }

      // 10. Study Buddy Bots subcollection
      match /bots/{botId} {
        allow read: if true;
        allow create: if request.auth != null &&
                      request.resource.data.keys().hasOnly(['id', 'name', 'addedBy', 'addedByName', 'createdAt']);
        allow delete: if request.auth != null;
        allow update: if false;
      }

      // 6. JoinRequests subcollection: anyone can create/delete their own request document, mods can update (approve/deny)
      match /joinRequests/{requestId} {
        allow read: if true;
        allow create: if (request.auth != null && requestId == request.auth.uid) || requestId.startsWith('guest_');
        allow update: if request.auth != null && 
                      get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role in ['admin', 'host', 'cohost'];
        allow delete: if (request.auth != null && (requestId == request.auth.uid || get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role in ['admin', 'host', 'cohost'])) ||
                      requestId.startsWith('guest_');
      }

      // 7. Keys subcollection
      match /keys/{keyId} {
        allow get, list: if true;
        allow create, delete: if (
          (request.auth != null && 
            (
              get(/databases/$(database)/documents/rooms/$(roomId)).data.creatorId == request.auth.uid ||
              get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role in ['admin', 'host', 'cohost']
            )
          ) ||
          get(/databases/$(database)/documents/rooms/$(roomId)).data.creatorId.startsWith('guest_')
        );
      }

      // 8. Persistent approval list
      match /approvedUsers/{userId} {
        allow read: if true;
        allow write: if (
          (request.auth != null && 
            (
              get(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.auth.uid)).data.role in ['admin', 'host', 'cohost'] ||
              (userId == request.auth.uid && get(/databases/$(database)/documents/rooms/$(roomId)).data.creatorId == request.auth.uid) ||
              (userId == request.auth.uid && request.resource.data.keys().hasAll(['joinKey']) && 
               exists(/databases/$(database)/documents/rooms/$(roomId)/keys/$(request.resource.data.joinKey)))
            )
          ) ||
          (
            userId.startsWith('guest_') && 
            (
              get(/databases/$(database)/documents/rooms/$(roomId)).data.creatorId.startsWith('guest_') ||
              (request.resource.data.keys().hasAll(['joinKey']) && 
               exists(/databases/$(database)/documents/rooms/$(roomId)/keys/$(request.resource.data.joinKey)))
            )
          )
        );
      }

      // 9. WebRTC signals subcollection (legacy/cleanup)
      match /signals/{signalId} {
        allow read, write: if request.auth != null;
        match /candidates/{candidateId} {
          allow read, write: if request.auth != null;
        }
      }
    }
  }
}
